{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mbse.local/schema/mbse-model-v0",
  "title": "MBSE shared model definitions v0",
  "description": "MBSE shared model definitions v0.",
  "$defs": {
    "document": {
      "type": "object",
      "required": ["schema_version", "document_id"],
      "properties": {
        "schema_version": {
          "description": "Concrete MBSE model schema version.",
          "type": "string",
          "minLength": 1
        },
        "document_id": {
          "description": "Global document identifier.",
          "$ref": "#/$defs/id"
        }
      }
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "action_language_executable": {
      "description": "Explicit action-language executable reference.",
      "type": "object",
      "required": ["kind", "module", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "action_language"
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "model_executable": {
      "description": "Executable reference to another MBSE model by document id.",
      "type": "object",
      "required": ["kind", "model_id"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "model"
        },
        "model_id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "executable": {
      "description": "Executable reference resolved by the runtime layer.",
      "oneOf": [
        {
          "$ref": "#/$defs/action_language_executable"
        },
        {
          "$ref": "#/$defs/model_executable"
        }
      ]
    },
    "typed_value_base": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signed": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "type": {
              "const": "signed"
            },
            "min": {
              "type": "integer"
            },
            "max": {
              "type": "integer"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "unsigned": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "type": {
              "const": "unsigned"
            },
            "min": {
              "type": "integer",
              "minimum": 0
            },
            "max": {
              "type": "integer"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "float": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "type": {
              "const": "float"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "bool": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "bool"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "enum": {
      "type": "object",
      "required": ["id", "values"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "enum_value": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["enum_id"],
          "properties": {
            "type": {
              "const": "enum"
            },
            "enum_id": {
              "$ref": "#/$defs/id"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "variable": {
      "oneOf": [
        {
          "type": "object",
          "required": ["name", "type", "min", "max", "default_value"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "signed"
            },
            "min": {
              "type": "integer"
            },
            "max": {
              "type": "integer"
            },
            "default_value": {
              "type": "integer",
              "description": "Default value for this declared variable."
            }
          }
        },
        {
          "type": "object",
          "required": ["name", "type", "min", "max", "default_value"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "unsigned"
            },
            "min": {
              "type": "integer",
              "minimum": 0
            },
            "max": {
              "type": "integer"
            },
            "default_value": {
              "type": "integer",
              "minimum": 0,
              "description": "Default value for this declared variable."
            }
          }
        },
        {
          "type": "object",
          "required": ["name", "type", "min", "max", "default_value"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "float"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            },
            "default_value": {
              "type": "number",
              "description": "Default value for this declared variable."
            }
          }
        },
        {
          "type": "object",
          "required": ["name", "type", "default_value"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "bool"
            },
            "default_value": {
              "type": "boolean",
              "description": "Default value for this declared variable."
            }
          }
        },
        {
          "type": "object",
          "required": ["name", "type", "enum_id", "default_value"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "enum"
            },
            "enum_id": {
              "$ref": "#/$defs/id"
            },
            "default_value": {
              "type": "string",
              "minLength": 1,
              "description": "Default value for this declared variable."
            }
          }
        }
      ]
    }
  }
}
