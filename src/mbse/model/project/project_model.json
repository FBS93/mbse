{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mbse.local/schema/mbse-project-model-v0",
  "title": "MBSE project model v0",
  "description": "MBSE project model v0.",
  "allOf": [
    {
      "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/document"
    }
  ],
  "type": "object",
  "required": [
    "project_root",
    "entrypoint"
  ],
  "unevaluatedProperties": false,
  "properties": {
    "schema_version": {
      "description": "MBSE project model v0.",
      "const": "mbse-project-model-v0"
    },
    "project_root": {
      "description": "Project root path relative to this project file.",
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "description": "Document id of the initial execution model.",
      "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
    }
  }
}
