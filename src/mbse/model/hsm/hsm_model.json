{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mbse.local/schema/mbse-hsm-model-v0",
  "title": "MBSE HSM model v0",
  "description": "MBSE HSM model v0.",
  "allOf": [
    {
      "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/document"
    }
  ],
  "type": "object",
  "required": [
    "events",
    "initial_transition",
    "states"
  ],
  "unevaluatedProperties": false,
  "properties": {
    "schema_version": {
      "description": "MBSE HSM model v0.",
      "const": "mbse-hsm-model-v0"
    },
    "events": {
      "description": "Event declarations.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "initial_transition": {
      "description": "Required root initial transition.",
      "$ref": "#/$defs/initial_transition"
    },
    "states": {
      "description": "Top-level states.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/state"
      }
    }
  },
  "$defs": {
    "parameter": {
      "oneOf": [
        {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/signed"
        },
        {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/unsigned"
        },
        {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/float"
        },
        {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/bool"
        },
        {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/enum_value"
        }
      ]
    },
    "event": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        }
      }
    },
    "initial_transition": {
      "type": "object",
      "required": ["target_id"],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "properties": {
        "on_entry": {
          "type": "array",
          "items": {
            "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
          }
        },
        "on_exit": {
          "type": "array",
          "items": {
            "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
          }
        }
      }
    },
    "guard_condition": {
      "type": "object",
      "required": ["guard_activity", "true_branch", "false_branch"],
      "additionalProperties": false,
      "properties": {
        "guard_activity": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
        },
        "true_branch": {
          "$ref": "#/$defs/guard_branch"
        },
        "false_branch": {
          "$ref": "#/$defs/guard_branch"
        }
      }
    },
    "guard_branch": {
      "description": "Branch target and optional activities for one guard condition outcome.",
      "type": "object",
      "required": ["target_id"],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
          }
        }
      }
    },
    "external_transition": {
      "type": "object",
      "required": ["event_id"],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "target_id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
          }
        },
        "guard_condition": {
          "$ref": "#/$defs/guard_condition"
        }
      },
      "oneOf": [
        {
          "required": ["target_id"],
          "not": {
            "required": ["guard_condition"]
          }
        },
        {
          "required": ["guard_condition"],
          "not": {
            "required": ["target_id"]
          }
        }
      ]
    },
    "internal_transition": {
      "description": "Internal handler that consumes an event without changing active state.",
      "type": "object",
      "required": ["event_id", "activities"],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/executable"
          }
        }
      }
    },
    "state": {
      "description": "State with optional nested states, hooks, and transitions.",
      "type": "object",
      "required": [
        "id",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "https://mbse.local/schema/mbse-model-v0#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/state"
          }
        },
        "hooks": {
          "$ref": "#/$defs/hooks"
        },
        "initial_transition": {
          "$ref": "#/$defs/initial_transition"
        },
        "external_transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_transition"
          }
        },
        "internal_transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/internal_transition"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["initial_transition"]
          },
          "then": {
            "required": ["states"],
            "properties": {
              "states": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
