{
  "version": "2.0.0",
  "options": {
    "env": {
      "TASKS_PATH": "${workspaceFolder}/.vscode/tasks"
    }
  },
  "tasks": [
    {
      "label": "run_opencode_web_gui",
      "type": "shell",
      "command": "${TASKS_PATH}/run_opencode_web_gui.sh"
    },
    {
      "label": "run_render_view_workbench",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "mbse_web_viewer.main",
        "render-view",
        "--no-browser"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/src",
          "MBSE_CLI_STATE_DIR": "${workspaceFolder}/.mbse-cli-state"
        }
      }
    }
  ]
}
